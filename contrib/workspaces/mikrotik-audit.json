        {"view": "term", "controller": "shell"}
      ]
    },
    {
      "title": "Firewall & NAT",
      "tab:connection": "admin@mikrotik",
      "blocks": [
        {"view": "term", "controller": "cmd", "cmd": "/ip firewall filter print", "cmd:runonstart": true},
        {"view": "term", "controller": "cmd", "cmd": "/ip firewall nat print", "cmd:runonstart": true}
      ]
    }
  ]
