---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Terminolgy — Sleek AI-powered terminal',
  description = 'Terminolgy is a modern, AI-powered terminal with GPU monitoring, multi-machine dashboards, and intelligent error analysis.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://terminolgy.io" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
